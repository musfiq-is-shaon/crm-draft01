{
  "info": {
    "name": "CRM API",
    "description": "Backend API for CRM (Flask). Set {{baseUrl}} to your backend (e.g. http://localhost:5000). Use **Login** to get a token; {{token}} is set automatically from the login response for use in auth-required requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "token", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "companyId", "value": "" },
    { "key": "contactId", "value": "" },
    { "key": "taskId", "value": "" },
    { "key": "saleId", "value": "" },
    { "key": "activityId", "value": "" },
    { "key": "currencyId", "value": "" },
    { "key": "expensePurposeId", "value": "" },
    { "key": "expenseId", "value": "" },
    { "key": "accountParticularId", "value": "" },
    { "key": "accountEntryId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var j = pm.response.json();",
                  "if (j && j.token) { pm.collectionVariables.set('token', j.token); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@apptriangle.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login",
            "description": "Returns user, token, expiresAt. Token is saved to collection variable {{token}}."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/auth/logout",
            "description": "Revoke current token (optional)."
          }
        },
        {
          "name": "Change password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"admin123\",\n  \"newPassword\": \"newpassword123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/change-password",
            "description": "Logged-in user changes own password. Requires Bearer token."
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "List users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/users",
            "description": "Returns all users (no auth enforced on backend)."
          }
        },
        {
          "name": "Get user by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/users/{{userId}}",
            "description": "Replace {{userId}} with actual user ID."
          }
        },
        {
          "name": "Update me (profile)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My Name\",\n  \"phone\": \"+1234567890\"\n}"
            },
            "url": "{{baseUrl}}/api/users/me",
            "description": "Logged-in user updates own name/phone. Requires Bearer."
          }
        },
        {
          "name": "Create user (admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New User\",\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"\",\n  \"role\": \"user\"\n}"
            },
            "url": "{{baseUrl}}/api/users",
            "description": "Admin only. Sends welcome email. role: admin | user."
          }
        },
        {
          "name": "Update user (admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Name\",\n  \"email\": \"updated@example.com\",\n  \"phone\": \"\",\n  \"role\": \"user\",\n  \"isActive\": true\n}"
            },
            "url": "{{baseUrl}}/api/users/{{userId}}",
            "description": "Admin only. Replace {{userId}}."
          }
        },
        {
          "name": "Set user password (admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"newPassword\": \"newpassword123\"\n}"
            },
            "url": "{{baseUrl}}/api/users/{{userId}}/password",
            "description": "Admin only. Replace {{userId}}."
          }
        }
      ]
    },
    {
